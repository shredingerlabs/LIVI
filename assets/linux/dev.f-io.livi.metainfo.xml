<component type="desktop-application">
  <id>dev.f-io.livi</id>
  <name>LIVI</name>
  <summary>LIVI - Linux In-Vehicle Infotainment</summary>
  <description>
    <p>
      LIVI is an open-source Apple CarPlay and Android Auto head unit for Linux.
      It supports hardware-accelerated video decoding, low-latency audio, multitouch
      and D-Pad navigation using CPC200-CCPA and CPC200-CCPW dongles.
    </p>
  </description>
