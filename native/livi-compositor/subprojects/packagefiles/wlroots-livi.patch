+void wlr_wl_output_set_fullscreen(struct wlr_output *output, bool fullscreen) {
+	struct wlr_wl_output *wl_output = get_wl_output_from_output(output);
+	assert(wl_output->xdg_toplevel != NULL);
+
+	if (!wl_output->initialized) {
+		return;
+	}
+	if (fullscreen) {
+		xdg_toplevel_set_fullscreen(wl_output->xdg_toplevel, NULL);
+	} else {
+		xdg_toplevel_unset_fullscreen(wl_output->xdg_toplevel);
+	}
+	wl_display_flush(wl_output->backend->remote_display);
+}
+
 struct wl_surface *wlr_wl_output_get_surface(struct wlr_output *output) {
 	struct wlr_wl_output *wl_output = get_wl_output_from_output(output);
 	return wl_output->surface;
