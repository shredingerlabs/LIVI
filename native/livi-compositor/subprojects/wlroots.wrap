[wrap-git]
url = https://gitlab.freedesktop.org/wlroots/wlroots.git
revision = 0.20
# LIVI: expose host-output control (fullscreen now; move/resize next) so the nested
# compositor can drive its host windows for app-kiosk + our own decorations.
diff_files = wlroots-livi.patch

[provide]
dependency_names = wlroots-0.20
wlroots-0.20 = wlroots
