{
  "extends": "./tsconfig.json",
  "include": [
    "src/renderer/src/env.d.ts",
    "src/renderer/src/**/*",
    "src/renderer/src/**/*.tsx",
    "src/preload/*.d.ts",
    "src/types/**/*",
    "jest.setup.ts",
    "jest.web.setup.ts"
  ],
  "exclude": ["**/__tests__/**", "**/*.test.ts", "**/*.test.tsx"],
  "compilerOptions": {
    "composite": false,
    "jsx": "react-jsx",
    "target": "es2024",
    "module": "es2022",
    "lib": ["dom", "dom.iterable", "es2024", "webworker"],
    "types": ["jest", "@testing-library/jest-dom", "w3c-web-usb", "vite/client"],
    "allowJs": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "bundler",
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noFallthroughCasesInSwitch": true,
    "noEmit": true,
    "paths": {
      "@renderer/*": ["./src/renderer/src/*"],
      "@projection/messages": ["./src/main/services/projection/messages/index.ts"],
      "@projection/messages/*": ["./src/main/services/projection/messages/*"],
      "@main/*": ["./src/main/*"],
      "@shared/*": ["./src/main/shared/*"],
      "@worker/*": ["./src/renderer/src/components/worker/*"],
      "@store/*": ["./src/renderer/src/store/*"],
      "@utils/*": ["./src/renderer/src/utils/*"],
      "@types/*": ["./src/renderer/src/types/*"]
    }
  }
}
